export EDITOR="nvim"
export GPG_TTY=$(tty)
export DOTNET_CLI_TELEMETRY_OPTOUT=1
export FUNCTIONS_CORE_TOOLS_TELEMETRY_OPTOUT=1

alias reload="source ~/.dotfilesrc && echo 'Reloaded run commands' || echo 'Failed'"
alias commit="pnpm dlx gitmoji-cli -c"
alias cm="commit"

# AI CLI Commands:
function copilot() {
  pnpm dlx @github/copilot "$@"
}

function gemini() {
  pnpm dlx @google/gemini-cli "$@"
}

alias cop='copilot'
alias gem='gemini'
alias jules="pnpm dlx @google/jules"
alias ask="llm -m fast -t cli-response"
alias chat="llm chat -m code"
